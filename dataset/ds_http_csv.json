{
	"name": "ds_http_csv",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_https",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Category": {
				"type": "string",
				"defaultValue": "test"
			},
			"FileName": {
				"type": "string",
				"defaultValue": "test"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "HttpServerLocation",
				"relativeUrl": {
					"value": "@concat('covid19/',dataset().Category,'/',dataset().FileName)",
					"type": "Expression"
				}
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	}
}